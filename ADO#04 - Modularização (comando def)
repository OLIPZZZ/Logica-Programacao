def calcular_desconto(valor, fidelidade):
    if fidelidade == 1:
        print("Desconto de 10% aplicado!")
        return valor * 0.90
    else:
        print("Sem desconto aplicado.")
        return valor

def calcular_frete(valor):
    if valor < 50:
        print("Taxa de entrega de R$ 5,00 adicionada.")
        return valor + 5
    else:
        print("Frete grátis!")
        return valor

def main():
    nome_cliente = input("Digite o nome do cliente: ")
    valor_pedido = float(input("Digite o valor do pedido: "))
    tem_fidelidade = int(input("Possui cartão fidelidade? (1-SIM, 0-NÃO): "))

    valor_com_desconto = calcular_desconto(valor_pedido, tem_fidelidade)
    valor_final = calcular_frete(valor_com_desconto)

    print("\n--- RESUMO DO CHECKOUT ---")
    print(f"Cliente: {nome_cliente}")
    print(f"Valor final a pagar: R$ {valor_final:.2f}")

if __name__ == "__main__":
    main()
